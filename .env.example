# 代理服务器配置
PORT=3000
HTTPS_PORT=8443

# 要拦截的域名
TARGET_DOMAIN=api.openai.com

# 转发目标（你的后端服务）
BACKEND_URL=http://192.168.1.100:8000

# 是否启用 HTTPS（需要证书）
ENABLE_HTTPS=true

# 证书路径（自动生成）
CERT_DIR=./certs

# 是否自动修改 hosts 文件（需要 sudo 权限）
AUTO_MODIFY_HOSTS=false

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info
